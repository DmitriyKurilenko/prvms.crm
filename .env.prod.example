# ============================================================
# prvms.crm Platform — Production Environment Template
# Copy to .env.prod and fill in all values before deploying.
# ============================================================

# Django Core
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET_KEY
DEBUG=False
ALLOWED_HOSTS=demo.example.com

# CSRF / HTTPS
CSRF_TRUSTED_ORIGINS=https://demo.example.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# Database
DB_NAME=platform_db
DB_USER=platform
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgres://platform:CHANGE_ME_STRONG_PASSWORD@db:5432/platform_db

# Redis (password required in production)
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# Encryption keys
# Generate: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
FIELD_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE_KEY
SALT_KEY=CHANGE_ME_BASE64_32_BYTE_KEY

# Platform domain (used in redirect URLs, webhook callbacks, etc.)
PLATFORM_DOMAIN=demo.example.com
PLATFORM_PROTOCOL=https
FRONTEND_APP_URL=https://demo.example.com
# Allow public schema fallback — needed until first tenant is created
SHOW_PUBLIC_IF_NO_TENANT_FOUND=True

# Nginx (set automatically by setup-ssl.sh, or fill manually)
NGINX_SERVER_NAME=demo.example.com
NGINX_SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
NGINX_SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# CORS (same domain — no wildcards needed)
CORS_ALLOWED_ORIGINS=https://demo.example.com

# S3-compatible storage for media files (VK Cloud S3, Yandex Object Storage, etc.)
S3_BUCKET_NAME=platform-demo
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_ENDPOINT_URL=https://CHANGE_ME.hb.ru-msk.vkcloud-storage.ru
S3_REGION=ru-msk

# Email (use SMTP in production; console backend for demo)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@demo.example.com

# SMS (stub = no real SMS, OTP logged to console)
SMS_PROVIDER=stub
SMS_API_KEY=
SMS_SENDER_NAME=Platform

# Telegram bot for notifications (optional for demo)
TELEGRAM_NOTIFICATION_BOT_TOKEN=

# External CRM OAuth (leave empty if not demoing integrations)
BITRIX24_APP_ID=
BITRIX24_APP_SECRET=
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=

# Payment (YooKassa — leave empty if not demoing billing)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Webhook base URL (for incoming CRM webhooks)
WEBHOOK_BASE_URL=https://demo.example.com

# FreeSWITCH (disabled in tech demo — do not uncomment unless running telephony profile)
# FREESWITCH_ESL_HOST=freeswitch
# FREESWITCH_ESL_PORT=8021
# FREESWITCH_ESL_PASSWORD=ClueCon
# FREESWITCH_WSS_URL=wss://demo.example.com:7443
