# ─── Public hostname / Traefik ───────────────────────────────────────────────
# DNS A-record for this hostname must already point to the VPS public IP.
PUBLIC_HOSTNAME=crm.prvms.ru

# ─── Database ────────────────────────────────────────────────────────────────
DB_NAME=platform_db
DB_USER=platform
DB_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD
# Used by Django via env DATABASE_URL.
DATABASE_URL=postgres://platform:CHANGE_ME_LONG_RANDOM_PASSWORD@db:5432/platform_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ─── Django core ─────────────────────────────────────────────────────────────
DEBUG=False
# 64+ random chars, do not reuse the dev key.
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY_64_CHARS_MIN
ALLOWED_HOSTS=crm.prvms.ru,*.crm.prvms.ru
CSRF_TRUSTED_ORIGINS=https://crm.prvms.ru
CORS_ALLOWED_ORIGINS=https://crm.prvms.ru

# Behind Traefik TLS termination — Django sees X-Forwarded-Proto=https.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# Tenant resolver fallback (dev-only; in prod each tenant has its own subdomain)
SHOW_PUBLIC_IF_NO_TENANT_FOUND=False

# Frontend origin for invite links / redirects.
FRONTEND_APP_URL=https://crm.prvms.ru
PLATFORM_DOMAIN=crm.prvms.ru
PLATFORM_PROTOCOL=https
WEBHOOK_BASE_URL=https://crm.prvms.ru

# ─── Email (transactional: invites, signed PDFs) ─────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@prvms.ru
EMAIL_HOST_PASSWORD=CHANGE_ME_SMTP_PASSWORD
DEFAULT_FROM_EMAIL=noreply@prvms.ru

# ─── Field-level encryption (Tenant credentials, integration tokens) ─────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
FIELD_ENCRYPTION_KEY=CHANGE_ME_FIELD_ENCRYPTION_KEY

# ─── Hermes AI Assistant (DEC-029) ───────────────────────────────────────────
HERMES_API_URL=http://hermes:8642
HERMES_API_KEY=CHANGE_ME_HERMES_API_KEY
HERMES_WEBHOOK_SECRET=CHANGE_ME_HERMES_WEBHOOK_SECRET
# Optional — only if Hermes uses OpenCode.ai cloud provider.
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://api.opencode.ai

# ─── Telegram bot (notifications + auth linking) ─────────────────────────────
TELEGRAM_NOTIFICATION_BOT_TOKEN=
TELEGRAM_NOTIFICATION_BOT_USERNAME=

# ─── Payment provider (YooKassa) ─────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://crm.prvms.ru/app/subscription

# ─── External CRM marketplace (amoCRM / Bitrix24) ────────────────────────────
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=https://crm.prvms.ru/api/integrations/amocrm/callback/
BITRIX24_APP_ID=
BITRIX24_APP_SECRET=

# ─── SMS provider (signing OTP) ──────────────────────────────────────────────
SMS_PROVIDER=stub
SMS_API_KEY=
SMS_SENDER_NAME=PRVMS

# ─── S3 / object storage (optional, for media offload) ───────────────────────
# Leave S3_BUCKET_NAME empty to keep media on the local /opt/crm_prvms/media volume.
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_REGION=ru-msk

# ─── FreeSWITCH (telephony) ──────────────────────────────────────────────────
# Leave defaults — telephony container is NOT included in this stack by default.
FREESWITCH_ESL_HOST=freeswitch
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon
FREESWITCH_WSS_URL=wss://crm.prvms.ru:7443
SIP_BASE_DOMAIN=sip.crm.prvms.ru
