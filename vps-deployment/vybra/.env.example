# Database
DB_NAME=vybra
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_LONG_PASSWORD

# Redis
REDIS_URL=redis://redis:6379/0

# Django
DEBUG=False
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY
ALLOWED_HOSTS=vybra.prvms.ru

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Selenium (Web scraping)
SELENIUM_REMOTE_URL=http://selenium:4444/wd/hub
SELENIUM_SLEEP_SCALE=0.8

# Parsing configs
WB_BATCH_PARSE_RETRIES=2
WB_BATCH_PARSE_TIMEOUT=25
WB_PARSER_RETRY_ATTEMPTS=2
WB_NIGHTLY_RECOVERY_ENABLED=true

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
