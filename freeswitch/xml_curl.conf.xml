<configuration name="xml_curl.conf" description="CRM Dynamic Dialplan and Directory">
  <bindings>

    <!-- Configuration: FreeSWITCH asks Django for sofia gateway definitions
         at startup and on 'sofia rescan'. Returns all active SIP trunks.  -->
    <binding name="configuration">
      <param name="gateway-url" value="http://web:8000/telephony/configuration/"/>
      <param name="bindings" value="configuration"/>
      <param name="method" value="POST"/>
    </binding>

    <!-- Dialplan: FreeSWITCH asks Django how to route every call -->
    <binding name="dialplan">
      <param name="gateway-url" value="http://web:8000/telephony/dialplan/"/>
      <param name="bindings" value="dialplan"/>
      <param name="method" value="POST"/>
    </binding>

    <!-- Directory: FreeSWITCH asks Django to authenticate SIP extensions
         when a softphone (SIP.js / WebRTC) registers or places a call     -->
    <binding name="directory">
      <param name="gateway-url" value="http://web:8000/telephony/directory/"/>
      <param name="bindings" value="directory"/>
      <param name="method" value="POST"/>
    </binding>

  </bindings>
</configuration>
