<configuration name="acl.conf" description="Network Lists">
  <network-lists>
    <!--
      crm_trusted: список сетей, которым доверяет FreeSWITCH.
      В production замените 0.0.0.0/0 на IP основного CRM-сервера.
    -->
    <list name="crm_trusted" default="deny">
      <node type="allow" cidr="0.0.0.0/0"/>
    </list>
  </network-lists>
</configuration>
