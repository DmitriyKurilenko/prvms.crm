# Django
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=*

# Host ports (set unique values per project copy)
WEB_HOST_PORT=18100
FRONTEND_DEV_HOST_PORT=15173
FRONTEND_PROD_HOST_PORT=14173
DB_HOST_PORT=15432
REDIS_HOST_PORT=16379

# Database
DATABASE_URL=postgres://platform:platform_dev@db:5432/platform_db

# Redis
REDIS_URL=redis://redis:6379/0

# Encryption
FIELD_ENCRYPTION_KEY=generate-32-byte-key-base64-here
SALT_KEY=generate-32-byte-key-base64-here

# SMS provider (для OTP)
SMS_PROVIDER=stub
SMS_API_KEY=
SMS_SENDER_NAME=Platform

# Email
# Если EMAIL_BACKEND не задан, settings.py автоматически выбирает SMTP, когда
# заполнен SMTP_HOST, и console, когда SMTP_HOST пуст. Раскомментируйте строку
# ниже, только если хотите принудительно переопределить автовыбор.
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@platform.ru

# ---- SMTP (маппится на Django EMAIL_* в settings.py) ----
# SMTP_SECURE=true → неявный TLS (порт 465); false → STARTTLS (порт 587).
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# CONTACT_TO — адрес-получатель заявок с формы лендинга (SUPPORT_EMAIL).
# CONTACT_FROM — From-адрес исходящих писем (обычно совпадает с SMTP_USER).
CONTACT_TO=
CONTACT_FROM=

# Bitrix24 App (для OAuth iframe-приложения)
BITRIX24_APP_ID=
BITRIX24_APP_SECRET=

# amoCRM App (для OAuth)
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=

# Platform
PLATFORM_DOMAIN=localhost:18100
PLATFORM_PROTOCOL=http
FRONTEND_APP_URL=http://localhost:15173
SHOW_PUBLIC_IF_NO_TENANT_FOUND=True

# Telephony: MTS Exolve (Numbering API + SIP API + Web Voice SDK)
EXOLVE_API_BASE=https://api.exolve.ru
EXOLVE_API_KEY=
EXOLVE_SIP_DOMAIN=sip.exolve.ru
# WSS WebRTC endpoint for the Web Voice SDK (leave empty to use SDK default)
EXOLVE_WSS_URL=
# Secret added to IPCR / Call-Events webhook URLs (?key=...)
EXOLVE_WEBHOOK_SECRET=
# Public HTTPS base for webhooks if different from PLATFORM_* (e.g. https://crm.prvms.ru)
EXOLVE_PUBLIC_BASE_URL=
# Reserve number Exolve dials if our IPCR URL is unreachable
EXOLVE_IPCR_RESERVE=

# Telegram Bot (платформенный бот для уведомлений)
TELEGRAM_NOTIFICATION_BOT_TOKEN=
TELEGRAM_NOTIFICATION_BOT_USERNAME=

# Hermes AI Assistant
HERMES_API_PORT=18642
HERMES_API_KEY=change-me
OPENCODE_API_TOKEN=

# ВКонтакте: ID standalone-приложения для OAuth подключения каналов.
# Регистрируется один раз на vk.com/dev. См. docs/user-guide/admin/vk-app-setup.md
VK_APP_ID=

# Frontend (Vite)
VITE_API_URL=http://localhost:18100/api

# CORS (укажите frontend origin(ы), включая localhost/127.0.0.1 при необходимости)
CORS_ALLOWED_ORIGINS=http://localhost:15173,http://127.0.0.1:15173,http://localhost:14173,http://127.0.0.1:14173
